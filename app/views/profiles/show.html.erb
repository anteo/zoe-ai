<%= component :"ui/modal", width: "w-xl" do |m| %>
  <% m.with_title do %>
    <span><%= t(:label_profile) %></span>
  <% end %>

  <%= simple_form_for @user, url: profile_path, method: :patch, html: { class: "space-y-5", multipart: true } do |f| %>
    <%#= f.error_notification %>

    <div class="flex items-center gap-4">
      <%= component :"ui/avatar_input",
                    form: f,
                    removable: true do |component| %>
        <%= avatar_for_user(@user, css_class: "w-20 h-20", id: "profile-avatar-preview") %>
        <% component.with_fallback do %>
          <%= avatar_for_user(@user, css_class: "w-20 h-20", id: "profile-avatar-preview", fallback: true) %>
        <% end %>
      <% end %>

      <div class="min-w-0">
        <div class="truncate text-lg font-semibold"><%= @user.full_name.presence || @user.email %></div>
        <div class="truncate text-sm opacity-70"><%= @user.email %></div>
      </div>
    </div>

    <div class="space-y-4">
      <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
        <%= f.input :first_name,
                    label: t(:label_first_name),
                    input_html: { required: true } %>
        <%= f.input :last_name,
                    label: t(:label_last_name) %>
      </div>
      <%= f.input :email,
                  label: t(:label_email),
                  input_html: { required: true } %>
      <%= f.input :password,
                  label: t(:label_new_password_optional) %>
      <%= f.input :password_confirmation,
                  label: t(:label_password_confirmation) %>
    </div>

    <div class="modal-action">
      <%= f.button :submit, t(:label_save), class: "btn btn-primary" %>
    </div>
  <% end %>
<% end %>
