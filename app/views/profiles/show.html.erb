<div class="min-h-screen bg-base-200 p-4">
  <div class="max-w-2xl mx-auto space-y-4">
    <div class="flex justify-between items-center">
      <h1 class="text-2xl font-semibold"><%= t(:label_profile) %></h1>
      <div class="flex gap-2">
        <%= link_to t(:label_edit_profile), edit_profile_path, class: "btn btn-primary" %>
        <%= link_to t(:label_back), root_path, class: "btn btn-ghost" %>
      </div>
    </div>

    <div class="card bg-base-100 shadow">
      <div class="card-body gap-3">
        <div>
          <div class="text-sm opacity-70"><%= t(:label_first_name) %></div>
          <div class="font-medium"><%= @user.first_name.presence || "-" %></div>
        </div>
        <div>
          <div class="text-sm opacity-70"><%= t(:label_last_name) %></div>
          <div class="font-medium"><%= @user.last_name.presence || "-" %></div>
        </div>
        <div>
          <div class="text-sm opacity-70"><%= t(:label_email) %></div>
          <div class="font-medium"><%= @user.email %></div>
        </div>
      </div>
    </div>
  </div>
</div>
