<div class="min-h-screen bg-base-200 p-4">
  <div class="max-w-2xl mx-auto space-y-4">
    <div class="flex justify-between items-center">
      <h1 class="text-2xl font-semibold"><%= t(:label_edit_profile) %></h1>
      <%= link_to t(:label_back), profile_path, class: "btn btn-ghost" %>
    </div>

    <div class="card bg-base-100 shadow">
      <div class="card-body">
        <%= simple_form_for @user, url: profile_path, html: { class: "space-y-4", method: :patch } do |f| %>
          <%= f.input :first_name,
                      label: t(:label_first_name),
                      placeholder: t(:placeholder_first_name),
                      input_html: {required: true} %>
          <%= f.input :last_name,
                      label: t(:label_last_name),
                      placeholder: t(:placeholder_last_name) %>
          <%= f.input :email,
                      label: t(:label_email),
                      placeholder: t(:placeholder_email),
                      input_html: {required: true} %>
          <%= f.input :password,
                      label: t(:label_new_password_optional),
                      placeholder: t(:placeholder_password) %>
          <%= f.input :password_confirmation,
                      label: t(:label_password_confirmation),
                      placeholder: t(:placeholder_password_confirmation) %>

          <div class="flex gap-2">
            <%= f.button :submit, t(:label_save), class: "btn btn-primary" %>
            <%= link_to t(:label_cancel), profile_path, class: "btn btn-ghost" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
