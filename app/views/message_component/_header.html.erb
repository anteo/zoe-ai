<div class="chat-header px-3 flex items-center gap-1 mb-1">
  <% if message.persisted? && is_current_user %>
    <span class="opacity-0 group-hover:opacity-100 transition-opacity flex items-center gap-0.5 mr-1">
      <button class="btn btn-ghost btn-xs p-0.5 min-h-0 h-auto"
              title="<%= t(:label_edit) %>"
              data-action="click->message#startEdit">
        <span class="icon-[lucide--pencil] w-3 h-3"></span>
      </button>
      <%= button_to resend_message_path(message), method: :post,
            class: "btn btn-ghost btn-xs p-0.5 min-h-0 h-auto",
            title: t(:label_resend),
            data: { turbo_stream: true } do %>
        <span class="icon-[lucide--rotate-ccw] w-3 h-3"></span>
      <% end %>
      <%= button_to message_path(message), method: :delete,
            class: "btn btn-ghost btn-xs p-0.5 min-h-0 h-auto text-error",
            title: t(:label_delete),
            data: { turbo_confirm: t(:confirm_delete_message), turbo_stream: true } do %>
        <span class="icon-[lucide--trash-2] w-3 h-3"></span>
      <% end %>
    </span>
  <% end %>
  <span class="font-medium"><%= sender.name %></span>
  <time class="text-xs opacity-50 ml-2"><%= message.created_at.strftime("%H:%M") %></time>
  <% if message.persisted? && !is_current_user %>
    <span class="opacity-0 group-hover:opacity-100 transition-opacity flex items-center gap-0.5 ml-1">
      <%= button_to message_path(message), method: :delete,
            class: "btn btn-ghost btn-xs p-0.5 min-h-0 h-auto text-error",
            title: t(:label_delete),
            data: { turbo_confirm: t(:confirm_delete_message), turbo_stream: true } do %>
        <span class="icon-[lucide--trash-2] w-3 h-3"></span>
      <% end %>
    </span>
  <% end %>
</div>
