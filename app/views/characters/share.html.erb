<%= component :ui__modal, width: "w-xl" do |m| %>
  <% m.with_title do %>
    <span><%= t(:label_share_character) %></span>
  <% end %>

  <%= simple_form_for @character_share_form,
                      url: deliver_share_character_path(@character),
                      html: { class: "space-y-4" } do |f| %>
    <p class="text-sm"><%= t(:text_character_share_prompt, character: @character.name) %></p>

    <%= f.input :email,
                as: :email,
                label: false,
                required: true,
                input_html: {
                  autofocus: true,
                  class: "input-bordered"
                } %>

    <div class="modal-action">
      <%= f.submit t(:label_send), class: "btn btn-primary" %>
    </div>
  <% end %>
<% end %>
