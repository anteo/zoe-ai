<%= component :ui__modal, width: "w-xl" do |m| %>
  <% m.with_title do %>
    <%= t(:label_create_character) %>
  <% end %>

  <% m.with_footer do %>
    <%= submit_tag t(:label_save), class: "btn btn-primary" %>
  <% end %>

  <%= simple_form_for @character, html: { class: "space-y-1" } do |f| %>
    <%= hidden_field_tag :select_on_save, params[:select_on_save] %>

    <%= f.input :name,
                label: false,
                required: true,
                input_html: {
                  autofocus: true,
                  class: "input-ghost outline-none text-xl bg-transparent",
                  maxlength: 50
                } %>

    <%= f.input :bio,
                label: false,
                input_html: {
                  class: "textarea-ghost outline-none bg-transparent",
                  maxlength: 160
                } %>
  <% end %>
<% end %>
