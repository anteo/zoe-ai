<%= component :"ui/modal", width: "w-xl" do |m| %>
  <% m.with_title do %>
    <span><%= t(:label_create_character) %></span>
  <% end %>

  <%= simple_form_for @character, html: { class: "space-y-1" } do |f| %>
    <%= hidden_field_tag :select_on_save, params[:select_on_save] %>

    <%= f.input :name,
                label: false,
                required: true,
                input_html: {
                  autofocus: true,
                  class: "input-ghost outline-none",
                  placeholder: t(:placeholder_enter_character_name),
                  maxlength: 50
                } %>

    <%= f.input :bio,
                label: false,
                input_html: {
                  class: "textarea-ghost outline-none",
                  maxlength: 160,
                  placeholder: t(:placeholder_enter_character_bio),
                } %>

    <div class="modal-action">
      <%= f.submit t(:label_save), class: "btn btn-primary" %>
    </div>
  <% end %>
<% end %>
