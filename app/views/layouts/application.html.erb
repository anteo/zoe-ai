<!DOCTYPE html>
<html data-controller="theme">
<head>
  <title><%= content_for(:title) || t(:label_app_title) %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="turbo-refresh-method" content="morph">
  
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= yield :head %>

  <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
  <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32">
  <link rel="icon" href="/favicon-16x16.png" type="image/png" sizes="16x16">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180">

  <%= stylesheet_link_tag "application" %>
  <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
</head>

<body data-controller="form-errors">
<div id="modal-stack"></div>
<%= turbo_stream_from current_user if user_signed_in? %>
<%= component :"ui/admin_console_modal" if current_user&.admin? %>

<%= yield %>

<div id="top-alerts" class="flash-stack fixed top-4 left-1/2 -translate-x-1/2 z-50 w-full max-w-2xl px-4 space-y-2 pointer-events-none">
  <% if flash.any? || content_for?(:top_alerts) %>
    <% flash.each do |type, message| %>
      <% next if message.blank? %>
      <%= component :"ui/flash_alert", type:, message: %>
    <% end %>
    <%= yield :top_alerts %>
  <% end %>
</div>

<%= render 'shared/turbo_confirm_modal' %>
</body>
</html>
