<%= render "devise/shared/auth_shell" do %>
  <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-2" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <%= f.input :first_name,
                label: t(:label_first_name),
                input_html: {autocomplete: "given-name"} %>
    <%= f.input :last_name,
                label: t(:label_last_name),
                input_html: {autocomplete: "family-name"} %>
    <%= f.input :email,
                label: t(:label_email),
                input_html: {autofocus: true, autocomplete: "email"} %>

    <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
      <div class="alert alert-info text-sm mt-2">
        <span><%= t(:text_pending_confirmation, email: resource.unconfirmed_email) %></span>
      </div>
    <% end %>

    <%= f.input :password,
                label: t(:label_new_password_optional),
                hint: (@minimum_password_length ? t(:text_password_minimum, count: @minimum_password_length) : nil),
                input_html: {autocomplete: "new-password"} %>
    <%= f.input :password_confirmation,
                label: t(:label_password_confirmation),
                input_html: {autocomplete: "new-password"} %>
    <%= f.input :current_password,
                label: t(:label_current_password_required),
                hint: t(:text_current_password_help),
                input_html: {autocomplete: "current-password"} %>

    <%= f.button :submit, t(:label_save), class: "btn btn-primary mt-4 w-full" %>
  <% end %>

  <div class="divider my-1"></div>
  <div class="flex items-center justify-between gap-3">
    <%= link_to t(:label_back), root_path, class: "btn btn-ghost btn-sm" %>
    <%= button_to t(:label_cancel_account), registration_path(resource_name),
                  method: :delete,
                  data: { turbo_confirm: t(:confirm_cancel_account) },
                  class: "btn btn-outline btn-error btn-sm" %>
  </div>
<% end %>
