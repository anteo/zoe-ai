<%= render "devise/shared/auth_shell" do %>
  <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-4" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
      <%= f.input :first_name,
                  label: t(:label_first_name),
                  input_html: {autofocus: true, autocomplete: "given-name"} %>
      <%= f.input :last_name,
                  label: t(:label_last_name),
                  input_html: {autocomplete: "family-name"} %>
    </div>

    <%= f.input :email, label: t(:label_email), input_html: {autocomplete: "email"} %>

    <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
      <%= f.input :password,
                  label: t(:label_password),
                  hint: (@minimum_password_length ? t(:text_password_minimum, count: @minimum_password_length) : nil),
                  input_html: {autocomplete: "new-password"} %>
      <%= f.input :password_confirmation,
                  label: t(:label_password_confirmation),
                  input_html: {autocomplete: "new-password"} %>
    </div>

    <%= f.button :submit, t(:label_register), class: "btn btn-primary mt-2 w-full" %>
  <% end %>

  <div class="divider my-1"></div>
  <div class="space-y-2">
    <%= render "devise/shared/links" %>
  </div>
<% end %>
