<%= component :"ui/modal",
              width: "max-w-3xl",
              padding: false,
              main_classes: "overflow-hidden",
              header: false,
              frame_id: "settings-modal" do |m| %>
  <% m.with_title { t(:label_settings) } %>

  <%= turbo_frame_tag "settings-body" do %>
    <%= component :"ui/settings", section: @section %>
  <% end %>
<% end %>
