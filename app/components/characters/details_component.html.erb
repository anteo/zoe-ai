<div class="flex h-full min-h-0 w-full flex-col"
     data-controller="character-details character-instructions characters-images"
     data-action="character-facts:count-changed->character-details#updateFactsCountBadge"
     data-character-details-current-section-value="<%= default_section %>">
  <%= helpers.simple_form_for character,
                              html: { multipart: true, class: "flex h-full min-h-0 flex-col" },
                              data: { action: "submit->character-instructions#handleSubmit" } do |f| %>
    <section class="flex flex-col md:flex-row md:items-start md:justify-between gap-5 px-5 py-7">
      <div class="flex min-w-0 grow items-start gap-4">
        <%= component :"ui/avatar_input",
                      form: f,
                      icon_wrapper_class: "h-9 w-9 shrink-0",
                      removable: true,
                      disabled: !editable? do |component| %>
          <%= helpers.avatar_for_character(character, css_class: "w-24 h-24", id: "character-avatar-preview") %>
          <% component.with_fallback do %>
            <%= helpers.avatar_for_character(character, css_class: "w-24 h-24", id: "character-avatar-preview", fallback: true) %>
          <% end %>
        <% end %>

        <div class="min-w-0 grow space-y-2">
          <div class="flex items-start gap-3">
            <div class="min-w-0">
              <h2 class="truncate text-2xl font-semibold tracking-tight"><%= character.name %></h2>
              <div class="mt-1 flex flex-wrap gap-2">
                <span class="badge badge-sm w-fit <%= type_badge_class %>"><%= type_label %></span>
                <% if shared? %>
                  <span class="badge badge-sm badge-outline w-fit"><%= t(:label_shared) %></span>
                <% end %>
              </div>
            </div>

            <div class="flex shrink-0 items-center">
              <% if shareable? %>
                <%= link_to share_character_path(character),
                            class: "btn btn-circle btn-ghost",
                            title: t(:label_share_character),
                            data: { turbo_stream: true } do %>
                  <span class="icon-[lucide--share-2] h-5 w-5"></span>
                <% end %>
              <% end %>

              <% if deletable? %>
                <%= link_to character_path(character),
                            class: "btn btn-circle btn-ghost text-error",
                            title: destroy_title,
                            data: { turbo_method: :delete, turbo_confirm: destroy_confirm_text } do %>
                  <span class="icon-[lucide--trash-2] h-5 w-5"></span>
                <% end %>
              <% end %>
            </div>
          </div>

          <% if editable? %>
            <%= f.input :bio,
                        as: :string,
                        label: false,
                        input_html: {
                          class: "input-ghost bg-transparent px-0 text-sm outline-none rounded-md",
                          maxlength: 160,
                          placeholder: t(:placeholder_enter_character_bio)
                        } %>
          <% elsif character.bio.present? %>
            <p class="text-sm leading-6 opacity-70"><%= character.bio %></p>
          <% else %>
            <p class="text-sm leading-6 opacity-50"><%= t(:text_no_character_bio) %></p>
          <% end %>
        </div>
      </div>

      <% if editable? %>
        <%= f.submit t(:label_save), class: "btn btn-primary shrink-0" %>
      <% end %>
    </section>

    <section class="flex min-h-0 flex-1 flex-col">
      <nav role="tablist" class="tabs tabs-lift w-full">
        <span class="border-b border-base-300 w-5"></span>
        <% sections.each do |section| %>
          <button type="button"
                  role="tab"
                  aria-controls="<%= "#{section_frame_id(section[:key])}-panel" %>"
                  class="tab gap-2"
                  data-character-details-target="tab"
                  data-section="<%= section[:key] %>"
                  data-action="click->character-details#showSection"
                  title="<%= section[:label] %>">
            <span class="<%= section[:icon_class] %> h-4 w-4"></span>
            <span><%= section[:label] %></span>
            <% if section[:count].present? %>
              <% badge_data = {} %>
              <% badge_data[:character_instructions_target] = "countBadge" if section[:key] == "instructions" %>
              <% badge_data[:characters_images_target] = "countBadge" if section[:key] == "images" %>
              <% badge_data[:character_details_target] = "factsCountBadge" if section[:key] == "facts" %>
              <%= tag.span section[:count], class: "badge badge-sm badge-neutral", data: badge_data %>
            <% end %>
          </button>
        <% end %>
        <span class="grow border-b border-base-300"></span>
      </nav>

      <div class="flex min-h-0 flex-1 flex-col overflow-hidden bg-base-100 p-5">
        <% sections.each do |section| %>
          <% active = section[:key] == default_section %>
          <div id="<%= "#{section_frame_id(section[:key])}-panel" %>"
               role="tabpanel"
               class="<%= active ? "block" : "hidden" %> <%= section[:key] == "facts" ? "h-full overflow-hidden" : "overflow-y-auto" %>"
               data-character-details-target="panel"
               data-section="<%= section[:key] %>">
            <%= helpers.turbo_frame_tag section_frame_id(section[:key]),
                                        src: section_path(section[:key]),
                                        class: "block h-full",
                                        loading: "lazy" do %>
              <div class="flex items-center justify-center py-12">
                <span class="loading loading-spinner loading-xl text-neutral"></span>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>
</div>
