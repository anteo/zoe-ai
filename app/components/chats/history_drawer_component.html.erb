<div class="drawer drawer-end w-auto shrink-0"
     data-controller="history-drawer"
     data-action="keydown@window->history-drawer#handleKeydown"
     data-history-drawer-list-title-value="<%= t(:label_chat_history) %>"
     data-history-drawer-list-url-value="<%= history_list_chats_path %>">
  <input id="history-drawer-toggle"
         type="checkbox"
         tabindex="-1"
         class="drawer-toggle"
         data-history-drawer-target="toggle"
         data-action="change->history-drawer#handleToggleChange">

  <div class="drawer-content">
    <button type="button"
            class="btn btn-ghost"
            title="<%= t(:label_chat_history) %>"
            aria-label="<%= t(:label_chat_history) %>"
            data-action="history-drawer#open">
      <span class="icon-[lucide--history] w-4 h-4"></span>
      <span class="hidden md:inline"><%= t(:label_chat_history) %></span>
    </button>
  </div>

  <div class="drawer-side z-50">
    <label for="history-drawer-toggle"
           aria-label="<%= t(:label_close) %>"
           class="drawer-overlay"></label>

    <aside class="history-drawer-panel ml-auto h-full w-full max-w-[26rem] bg-base-100 shadow-xl transition-[max-width] duration-200 flex flex-col"
           data-history-drawer-target="panel">
      <header class="border-b border-base-300 px-4 py-3 flex items-center gap-2">
        <button type="button"
                class="btn btn-ghost btn-sm hidden lg:hidden"
                data-history-drawer-target="backButton"
                data-action="history-drawer#showList"
                title="<%= t(:label_back) %>">
          <span class="icon-[lucide--arrow-left] w-4 h-4"></span>
        </button>
        <div class="flex-1 min-w-0">
          <h2 class="font-semibold text-base truncate" data-history-drawer-target="title"><%= t(:label_chat_history) %></h2>
        </div>
        <button type="button" class="btn btn-ghost btn-sm" data-action="history-drawer#close" title="<%= t(:label_close) %>">
          <span class="icon-[lucide--x] w-4 h-4"></span>
        </button>
      </header>

      <div class="flex-1 min-h-0 flex justify-end">
        <div class="hidden min-h-0 border-r border-base-300 bg-base-100 lg:flex-1 w-full"
             data-history-drawer-target="detailView">
          <turbo-frame id="history-chat-detail"
                       data-history-drawer-target="detailFrame"
                       data-action="turbo:frame-load->history-drawer#finishFrameTransition"
                       class="history-chat-frame block h-full">
            <div class="h-full p-6 text-sm opacity-60"><%= t(:text_select_chat_history) %></div>
          </turbo-frame>
        </div>

        <div class="flex-1 min-h-0 lg:w-[26rem] lg:flex-none" data-history-drawer-target="listView">
          <turbo-frame id="history-chat-list"
                       data-history-drawer-target="listFrame"
                       data-action="turbo:frame-load->history-drawer#syncListState">
            <div class="h-full p-6 text-sm opacity-60"><%= t(:text_select_chat_history) %></div>
          </turbo-frame>
        </div>
      </div>
    </aside>
  </div>
</div>
