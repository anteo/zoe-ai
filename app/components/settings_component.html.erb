<%= component :modal, width: "max-w-3xl", padding: false, main_classes: "overflow-hidden", header: false do |m| %>
  <% m.with_title { t(:label_settings) } %>

  <div class="drawer drawer-open">
    <input type="checkbox" class="drawer-toggle" />
    <div class="drawer-content h-[65vh] overflow-y-auto">
      <%= helpers.turbo_frame_tag "settings-section",
                                  src: section_settings_path(@section),
                                  loading: "lazy" do %>
        <div class="flex items-center justify-center py-12">
          <span class="loading loading-spinner loading-xl text-neutral"></span>
        </div>
      <% end %>
    </div>
    <div class="drawer-side h-full overflow-hidden">
      <ul class="menu bg-base-200 h-full w-44 py-5 px-2 gap-0.5">
        <% SECTIONS.each do |section, opts| %>
          <li>
            <%= link_to settings_path(section:),
                        class: helpers.class_names("flex w-full items-center justify-start gap-2",
                                                   "menu-active" => active?(section)),
                        data: { turbo_frame: "modal" } do %>
              <span class="<%= opts[:icon] %> w-4 h-4 shrink-0"></span>
              <%= t(:"label_settings_#{section}") %>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
<% end %>
