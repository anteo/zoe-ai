<div class="dropdown dropdown-end ml-1"
     data-controller="admin-console-opener"
     data-admin-console-opener-admin-console-modal-outlet="#admin-console-modal">
  <div tabindex="0" role="button" class="btn btn-ghost btn-circle btn-sm">
    <%= avatar_for_user(current_user, id: "profile-menu-avatar") %>
  </div>
  <ul tabindex="0" class="dropdown-content menu bg-base-100 rounded-box shadow-lg border border-base-300 z-50 mt-1">
    <li class="menu-title">
      <span class="block font-semibold text-sm leading-tight"><%= current_user.full_name %></span>
      <span class="block text-xs"><%= current_user.email %></span>
    </li>
    <li>
      <%= link_to profile_path, data: { turbo_frame: "modal" } do %>
        <span class="icon-[lucide--user-round] w-4 h-4"></span>
        <%= t(:label_profile) %>
      <% end %>
    </li>
    <% if my_character %>
      <li>
        <%= link_to edit_character_path(my_character),
                    data: { turbo_frame: "modal" } do %>
          <span class="icon-[lucide--square-user-round] w-4 h-4"></span>
          <%= t(:label_my_character) %>
        <% end %>
      </li>
    <% end %>
    <% if current_user.admin? %>
      <li>
        <%= link_to settings_path, data: { turbo_frame: "modal" } do %>
          <span class="icon-[lucide--settings] w-4 h-4"></span>
          <%= t(:label_settings) %>
        <% end %>
      </li>
      <li>
        <button type="button" data-action="click->admin-console-opener#open">
          <span class="icon-[lucide--square-terminal] w-4 h-4"></span>
          <%= t(:label_console) %>
        </button>
      </li>
    <% end %>
    <li>
      <%= link_to destroy_user_session_path,
                  class: "text-error",
                  data: { turbo_method: :delete, turbo_confirm: t(:confirm_logout) } do %>
        <span class="icon-[lucide--log-out] w-4 h-4"></span>
        <%= t(:label_logout) %>
      <% end %>
    </li>
  </ul>
</div>
