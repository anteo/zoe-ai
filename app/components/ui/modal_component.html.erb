<dialog class="modal modal-open"
        data-controller="app-modal"
        data-app-modal-referrer-frame-id-value="<%= referrer_frame_id %>"
        data-action="cancel->app-modal#close click->app-modal#backdropClick app-modal:close->app-modal#close">
  <div class="<%= box_classes %>">
    <div class="relative max-h-screen overflow-hidden w-full">
      <% if header %>
        <div class="<%= header_classes %>">
          <h3 class="<%= title_classes %>"><%= title %></h3>
          <% if close_button %>
            <button type="button"
                    class="btn btn-ghost btn-sm btn-circle ml-auto"
                    data-action="click->app-modal#close"
                    aria-label="<%= t(:label_close) %>">
              <span class="icon-[lucide--x] w-5 h-5"></span>
              <span class="sr-only"><%= t(:label_close) %></span>
            </button>
          <% end %>
        </div>
      <% end %>

      <div class="<%= main_classes %>">
        <% if frame_id.present? %>
          <%= helpers.turbo_frame_tag frame_id, data: { app_modal_target: "frame" } do %>
            <%= content %>
          <% end %>
        <% else %>
          <%= content %>
        <% end %>
      </div>

      <% if footer? %>
        <div class="<%= footer_classes %>"><%= footer %></div>
      <% end %>
    </div>
  </div>
</dialog>
