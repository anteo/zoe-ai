<div class="flex h-full min-h-0 w-full flex-col"
     data-controller="character-form"
     data-character-form-current-section-value="<%= default_section %>">
  <%= helpers.simple_form_for character,
                              html: { multipart: true, class: "flex h-full min-h-0 flex-col" },
                              data: { action: "submit->character-form#handleSubmit" } do |f| %>
    <%= hidden_field_tag :refresh, refresh if refresh.present? %>

    <section class="flex flex-col md:flex-row md:items-center md:justify-between gap-5 px-5 py-7">
      <div class="flex min-w-0 items-center gap-4 md:grow-0 grow">
        <label class="group relative cursor-pointer shrink-0">
          <span data-character-form-target="avatarPreview">
            <%= helpers.avatar_for_character(character, css_class: "w-24 h-24", id: "character-avatar-preview") %>
          </span>
          <span class="absolute -bottom-1 -right-1 flex h-9 w-9 items-center justify-center rounded-2xl border border-base-300 bg-base-100 shadow-sm transition-transform group-hover:scale-105">
            <span class="icon-[lucide--camera] h-4 w-4"></span>
          </span>
          <%= f.file_field :avatar,
                           class: "hidden",
                           accept: "image/*",
                           data: { action: "change->character-form#handleAvatarChange" } %>
        </label>

        <div class="min-w-0 space-y-2 grow">
          <div class="flex flex-wrap flex-col items-left gap-1">
            <h2 class="truncate text-2xl font-semibold tracking-tight"><%= character.name %></h2>
            <span class="badge badge-sm <%= type_badge_class %>"><%= type_label %></span>
          </div>
        </div>

        <div class="flex">
          <button type="button"
                  class="btn btn-circle btn-ghost"
                  disabled>
            <span class="icon-[lucide--share-2] h-5 w-5"></span>
          </button>

          <% if deletable? %>
            <%= link_to character_path(character, refresh:),
                        class: "btn btn-circle btn-ghost text-error",
                        title: t(:label_delete),
                        data: { turbo_method: :delete, turbo_confirm: t(:confirm_delete_character) } do %>
              <span class="icon-[lucide--trash-2] h-5 w-5"></span>
            <% end %>
          <% end %>
        </div>
      </div>

        <%= f.submit t(:label_save), class: "btn btn-primary" %>
    </section>

    <section class="flex min-h-0 flex-1 flex-col">
      <nav role="tablist" class="tabs tabs-lift w-full">
        <span class="border-b border-base-300 w-5"></span>
        <% sections.each do |section| %>
          <button type="button"
                  role="tab"
                  aria-controls="<%= "#{section_frame_id(section[:key])}-panel" %>"
                  class="tab gap-2"
                  data-character-form-target="tab"
                  data-section="<%= section[:key] %>"
                  data-action="click->character-form#showSection"
                  title="<%= section[:label] %>">
            <span class="<%= section[:icon_class] %> h-4 w-4"></span>
            <span><%= section[:label] %></span>
            <% if section[:count].present? %>
              <% badge_data = section[:badge_target].present? ? { character_form_target: section[:badge_target] } : {} %>
              <%= tag.span section[:count], class: "badge badge-sm badge-neutral", data: badge_data %>
            <% end %>
          </button>
        <% end %>
        <span class="grow border-b border-base-300"></span>
      </nav>

      <div class="flex min-h-0 flex-1 flex-col overflow-hidden bg-base-100 p-5">
        <% sections.each do |section| %>
          <% active = section[:key] == default_section %>
          <div id="<%= "#{section_frame_id(section[:key])}-panel" %>"
               role="tabpanel"
               class="<%= active ? "block" : "hidden" %> overflow-y-auto"
               data-character-form-target="panel"
               data-section="<%= section[:key] %>">
            <%= helpers.turbo_frame_tag section_frame_id(section[:key]),
                                        src: section_path(section[:key]),
                                        loading: "lazy" do %>
              <div class="flex items-center justify-center py-12">
                <span class="loading loading-spinner loading-xl text-neutral"></span>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>
</div>
