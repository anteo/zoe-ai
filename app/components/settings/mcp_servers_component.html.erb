<div class="space-y-4">
  <%= turbo_stream_from MCPServer %>

  <% if mcp_servers.any? %>
    <table class="table table-zebra table-sm w-full rounded-box border border-base-300 bg-base-100">
      <thead>
        <tr>
          <th><%= t(:label_name) %></th>
          <th><%= t(:label_key) %></th>
          <th><%= t(:label_last_error) %></th>
          <th></th>
        </tr>
        </thead>
        <tbody>
        <%= component_collection(:settings__mcp_server_row, mcp_servers) %>
      </tbody>
    </table>
  <% else %>
    <p class="text-sm opacity-60"><%= t(:text_no_mcp_servers) %></p>
  <% end %>
</div>

<% header do %>
  <%= helpers.link_to new_mcp_server_path,
                      class: "btn btn-primary btn-sm",
                      data: { turbo_stream: true } do %>
    <span class="icon-[lucide--plus] h-4 w-4"></span>
    <%= t(:label_new) %>
  <% end %>
<% end %>
