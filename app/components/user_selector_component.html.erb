  <button class="btn btn-ghost" popovertarget="user-selector" style="anchor-name:--anchor-user-selector">
    <span class="font-bold"><%= current_user&.name || "Select User" %></span>
    <span class="w-8 h-8 rounded-full bg-base-100 flex items-center justify-center font-medium shadow-sm">
      A
    </span>
  </button>
  <ul class="dropdown menu p-3 shadow bg-base-100 rounded-box w-52 mt-1" popover id="user-selector" style="position-anchor:--anchor-user-selector; position-area: bottom span-left">
    <% user_options.each do |name, id| %>
      <li>
        <%= link_to name, select_user_path(user_id: id), data: { turbo_method: :post } %>
      </li>
    <% end %>
  </ul>
