<div id="message-<%= message.id || SecureRandom.uuid %>" class="<%= bubble_class %>">
  <div class="chat-header px-3">
    <span class="font-medium"><%= sender.name %></span>
    <time class="text-xs opacity-50 ml-2"><%= message.created_at.strftime("%H:%M") %></time>
  </div>

  <% if message.content.present? %>
    <div class="chat-bubble <%= bubble_color %>">
      <%= message.content %>
    </div>
  <% end %>
</div>

<% if message.attachments.attached? %>
  <div class="<%= bubble_class %>">
    <div class="chat-bubble bg-base-100 attachments-container ps-0 pe-0">
      <% if image_attachments.any? %>
        <div class="image-attachments">
          <% image_attachments.each do |attachment| %>
            <%= component :image_attachment, attachment: attachment %>
          <% end %>
        </div>
      <% end %>
      <% if file_attachments.any? %>
        <div class="file-attachments">
          <% file_attachments.each do |attachment| %>
            <%= component :attachment, attachment: attachment %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
