<div id="chat-input"
     data-controller="chat-input"
     data-chat-input-chat-id-value="<%= chat.id %>"
     data-chat-input-memorize-mode-value="<%= chat.memorize %>">
  <%= form_with model: Message.new, url: messages_path(chat_id: chat), class: "w-full", multipart: true,
               data: { action: "submit->chat-input#handleSubmit" } do |f| %>
    <div class="input h-auto w-full flex-col items-stretch whitespace-normal p-0 bg-base-100 border-base-200 shadow-sm outline">
      <div id="attachments-preview" class="hidden flex flex-wrap gap-2 p-2 border-b border-base-200" data-chat-input-target="attachmentsPreview"></div>
      <div class="flex items-end px-3 pt-3">
        <%= f.text_area :content,
            placeholder: t(:placeholder_chat_input),
            rows: 1,
            class: "flex-1 resize-none bg-transparent border-none outline-none focus:outline-none py-0.5 max-h-32",
            data: { chat_input_target: "textInput", action: "input->chat-input#handleInput keydown->chat-input#handleKeydown" } %>
      </div>
      <div class="mt-2 flex items-center justify-between gap-2 px-3 pb-2">
        <div class="flex items-center gap-2">
          <%= f.label :attachments, class: "btn btn-ghost btn-circle btn-sm cursor-pointer" do %>
            <%= content_tag :span, '', class: "icon-[lucide--paperclip] w-4 h-4" %>
            <%= f.file_field :attachments, multiple: true, class: "hidden",
                data: { action: "change->chat-input#displayAttachments", chat_input_target: "fileInput" } %>
          <% end %>
          <button type="button"
                  class="btn btn-ghost btn-sm gap-2"
                  data-chat-input-target="memorizeButton"
                  data-action="click->chat-input#toggleMemorize">
            <%= content_tag :span, '', class: "icon-[lucide--bookmark] w-4 h-4", data: { chat_input_target: "memorizeIcon" } %>
            <span class="leading-none"
                  data-chat-input-target="memorizeLabel"
                  data-label-on="<%= t(:label_memory_mode_on) %>"
                  data-label-off="<%= t(:label_memory_mode_off) %>"><%= t(:label_memory_mode_on) %></span>
          </button>
          <%= f.hidden_field :memorize, value: chat.memorize.to_s, data: { chat_input_target: "memorizeField" } %>
        </div>
        <div class="flex items-center gap-2">
          <div id="token-usage-gauge-<%= chat.id %>">
            <%= component :token_usage_gauge, chat: %>
          </div>
          <%= f.button class: "btn btn-sm gap-2",
                data: { chat_input_target: "sendButton" } do %>
            <%= content_tag :span, '', class: "icon-[lucide--send] w-4 h-4" %>
            <span><%= t(:label_send) %></span>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <template data-chat-input-target="attachmentTemplate">
    <div class="relative rounded-lg overflow-hidden border border-base-content/20 shrink-0 bg-base-200" data-attachment-index>
      <button type="button"
              class="absolute top-0.5 right-0.5 z-10 rounded-full bg-base-100/80 hover:bg-base-100 p-0.5 leading-none"
              data-action="click->chat-input#removeAttachment">
        <span class="icon-[lucide--x] w-3 h-3 block"></span>
      </button>
      <div data-attachment-content></div>
    </div>
  </template>
</div>
