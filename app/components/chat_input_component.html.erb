<div id="chat-input"
     data-controller="dialog-input"
     data-dialog-input-chat-id-value="<%= chat.id %>">
  <%= form_with model: Message.new, url: messages_path(chat_id: chat), class: "w-full", multipart: true do |f| %>
    <div class="input h-auto w-full flex-col items-stretch whitespace-normal p-0 overflow-hidden bg-base-100 border-base-200 shadow-sm">
      <div id="attachments-preview" class="hidden flex flex-wrap gap-2 p-2 border-b border-base-200" data-dialog-input-target="attachmentsPreview"></div>
      <div class="flex items-end gap-1 px-3 py-2">
        <%= f.text_area :content,
            placeholder: t(:placeholder_dialog_input),
            rows: 1,
            class: "flex-1 resize-none bg-transparent border-none outline-none focus:outline-none py-0.5 max-h-32",
            data: { dialog_input_target: "textInput", action: "input->dialog-input#handleInput keydown->dialog-input#handleKeydown" } %>
        <div class="flex items-center gap-1 shrink-0">
          <%= f.label :attachments, class: "btn btn-ghost btn-sm cursor-pointer p-1 h-auto min-h-0", title: t(:label_attach) do %>
            <%= content_tag :span, '', class: "icon-[lucide--paperclip] w-4 h-4" %>
            <%= f.file_field :attachments, multiple: true, class: "hidden",
                data: { action: "change->dialog-input#displayAttachments", dialog_input_target: "fileInput" } %>
          <% end %>
          <%= f.button class: "btn btn-ghost btn-sm p-1 h-auto min-h-0", title: t(:label_send) do %>
            <%= content_tag :span, '', class: "icon-[lucide--send] w-4 h-4" %>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <template data-dialog-input-target="attachmentTemplate">
    <div class="relative rounded-lg overflow-hidden border border-base-content/20 shrink-0 bg-base-200" data-attachment-index>
      <button type="button"
              class="absolute top-0.5 right-0.5 z-10 rounded-full bg-base-100/80 hover:bg-base-100 p-0.5 leading-none"
              data-action="click->dialog-input#removeAttachment">
        <span class="icon-[lucide--x] w-3 h-3 block"></span>
      </button>
      <div data-attachment-content></div>
    </div>
  </template>
</div>
