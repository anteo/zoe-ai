<div class="dropdown dropdown-end ml-1 group">
  <button class="btn btn-ghost gap-2 px-2">
    <%= avatar_for_character(current_partner) %>
    <span class="font-bold"><%= current_partner&.name %></span>
    <span class="icon-[lucide--chevron-down] w-4 h-4 opacity-70 transition-transform group-focus-within:rotate-180"></span>
  </button>

  <div class="dropdown-content p-1 shadow-lg bg-base-100 max-w-xl rounded-box mt-1 border border-base-300 overflow-x-auto" id="character-selector">
    <ul class="menu menu-horizontal items-start flex-nowrap gap-1">
      <% character_options.each do |character| %>
        <li>
        <%= link_to select_character_path(character.id),
                    data: { turbo_method: :post },
                    class: "rounded-md shrink-0 flex w-20 flex-col items-center gap-1 px-1 py-1.5" do %>
          <%= avatar_for_character(character, size: 28) %>
          <span class="block w-full text-xs font-medium leading-tight text-center whitespace-nowrap overflow-hidden text-ellipsis"><%= character.name %></span>
        <% end %>
        </li>
      <% end %>

      <li>
        <%= link_to new_character_path,
                    data: { turbo_frame: "modal" },
                    class: "rounded-md shrink-0 flex w-20 flex-col items-center gap-1 px-1 py-1.5" do %>
          <span class="w-8 h-8 rounded-full bg-base-100 text-xs shadow-sm flex items-center justify-center">
            <span class="icon-[lucide--plus]"></span>
          </span>
          <span class="block w-full text-xs font-medium leading-tight text-center whitespace-nowrap overflow-hidden text-ellipsis"><%= t(:label_new) %></span>
        <% end %>
      </li>
    </ul>
  </div>
</div>
