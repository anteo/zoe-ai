<context>
Today is <%= I18n.l(Time.zone.now, locale: :en) %>.
You are talking with <%= chat.character.name %> (ID: <%= chat.character.id %>).
<% if (time = chat.character.last_conversation_time(except: chat)).present? -%>
Your last conversation was <%= helpers.distance_of_time_in_words_to_now(time, locale: :en) %> ago.
<% end -%>
</context>

<characters>
<% chat.user.characters.order(:id).each do |character| -%>
<character id="<%= character.id %>" name="<%= character.name %>" role="<%= character.prompt_role(chat) %>" type="<%= character.prompt_type %>" />
<% end -%>
</characters>

<identity name="<%= chat.partner.name %>" role="you">
You are <%= chat.partner.name %>.
<%= chat.described_character(chat.partner, mode: :xml) %>
</identity>

<identity name="<%= chat.character.name %>" role="interlocutor">
<%= chat.character.name %> is the person you are talking to.
<%= chat.described_character(chat.character, mode: :xml) %>
</identity>
<% known_characters = chat.known_characters_with_description(mode: :xml) -%>
<% if known_characters.any? -%>

<known_characters>
<% known_characters.each do |character, description| -%>
<character id="<%= character.id %>" name="<%= character %>">
<%= description %>
</character>
<% end -%>
</known_characters>
<% end -%>

<events subject="<%= chat.character %>">
<%= AI::Actors::DescribeEvents.result(character: chat.character, mode: :xml).description %>
</events>
<% yesterday = chat.yesterday_summary -%>
<% if yesterday.present? -%>

<yesterday_conversation date="<%= Date.yesterday %>">
<%= yesterday %>
</yesterday_conversation>
<% end -%>

<instructions>
<%= chat.partner_instructions %>
</instructions>
