<context>
Today is <%= I18n.l(Time.zone.now, locale: :en) %>.
You are talking with <%= chat.character.name %> (ID: <%= chat.character.id %>).
<% if (time = chat.character.last_conversation_time(except: chat)).present? -%>
Your last conversation was <%= helpers.distance_of_time_in_words_to_now(time, locale: :en) %> ago.
<% end -%>
</context>

<identity name="<%= chat.partner.name %>" role="you">
You are <%= chat.partner.name %>.
<%= chat.partner.description %>
</identity>

<identity name="<%= chat.character.name %>" role="interlocutor">
<%= chat.character.name %> is the person you are talking to.
<%= chat.character.description %>
</identity>
<% known_characters = chat.other_known_characters.select { |c| c.description.present? } -%>
<% if known_characters.any? -%>

<known_characters>
<% known_characters.each do |character| -%>
<character name="<%= character %>">
<%= character.description %>
</character>
<% end -%>
</known_characters>
<% end -%>

<events subject="<%= chat.character %>">
<%= runtime.prompt :time_facts, grouped_facts: chat.character.grouped_time_facts, character: chat.character %>
</events>
<% yesterday = chat.yesterday_summary -%>
<% if yesterday.present? -%>

<yesterday_conversation date="<%= Date.yesterday %>">
<%= yesterday %>
</yesterday_conversation>
<% end -%>

<instructions>
<%= chat.partner_instructions %>
<% if defined?(additional_instructions) && additional_instructions.present? -%>
<%= additional_instructions.map { "* #{it}" }.join("\n") %>
<% end -%>
</instructions>
